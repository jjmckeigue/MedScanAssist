APP_NAME=MedScanAssist API
APP_ENV=development
# In development, set to true to require JWT (or API key) on protected routes like production.
# staging and production always enforce auth regardless of this value.
REQUIRE_AUTH=false
APP_HOST=0.0.0.0
APP_PORT=8000

# Data paths (use persistent storage on your host — serverless resets lose SQLite users)
DATASET_ROOT=./data/raw/chest_xray
UPLOAD_DIR=./backend/uploads
CHECKPOINT_PATH=./backend/checkpoints/best_model.onnx
MODEL_META_PATH=./backend/checkpoints/model_meta.json
HISTORY_DB_PATH=./backend/artifacts/history.db

# Inference
MODEL_ARCH=densenet121
CLASS_NAMES=normal,pneumonia
IMAGE_SIZE=224
DEFAULT_THRESHOLD=0.5
REQUIRE_CHECKPOINT=false
MAX_UPLOAD_BYTES=8388608

# JWT authentication (generate a strong random secret for production)
JWT_SECRET_KEY=change-me-generate-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email — required on any server where users register: BOTH SMTP_USER and SMTP_PASSWORD (Gmail: App Password)
# FRONTEND_URL = exact site origin (https://yourdomain.com) so links in emails open your SPA
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-sender@gmail.com
SMTP_PASSWORD=
SMTP_FROM_NAME=MedScanAssist
VERIFICATION_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_HOURS=1
FRONTEND_URL=https://medscanassist.com/

# Legacy API key (kept for backward compat; JWT is primary auth)
API_KEY=

# CORS (comma-separated origins allowed to call the API)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
