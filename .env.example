APP_NAME=MedScanAssist API
APP_ENV=development
REQUIRE_AUTH=false
APP_HOST=0.0.0.0
APP_PORT=8000

DATASET_ROOT=./data/raw/chest_xray
UPLOAD_DIR=./backend/uploads
CHECKPOINT_PATH=./backend/checkpoints/best_model.onnx
MODEL_META_PATH=./backend/checkpoints/model_meta.json
HISTORY_DB_PATH=./backend/artifacts/history.db

# Inference
MODEL_ARCH=densenet121
CLASS_NAMES=normal,pneumonia
IMAGE_SIZE=224
DEFAULT_THRESHOLD=0.5
REQUIRE_CHECKPOINT=false
MAX_UPLOAD_BYTES=8388608

# JWT authentication
JWT_SECRET_KEY=change-me-generate-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Per-account login throttling (complements per-IP slowapi limits).
# After LOGIN_MAX_ATTEMPTS consecutive failures, the account is locked for
# LOGIN_LOCKOUT_MINUTES. The counter auto-resets if the last failure was more
# than LOGIN_ATTEMPT_WINDOW_MINUTES ago, so isolated typos never accumulate.
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
LOGIN_ATTEMPT_WINDOW_MINUTES=15

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=sender@gmail.com
SMTP_PASSWORD=
SMTP_FROM_NAME=MedScanAssist
VERIFICATION_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_HOURS=1
FRONTEND_URL=https://medscanassist.com/

# Legacy API key, JWT is primary auth
API_KEY=

# Admin bootstrap: when set, the user registering with this email is created
# with role='admin'. If the account already exists, it is promoted on the next
# server start. Useful on hosts where the DB may be reset (free tiers, fresh
# disks) -- just re-register and you're admin again automatically. Leave blank
# to disable. Gmail addresses are normalized (dots stripped) before comparison.
ADMIN_BOOTSTRAP_EMAIL=

# CORS (comma-separated origins allowed to call the API).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
